#!/usr/bin/env bash
# tjp-setup — one-time workspace setup for TJP pipeline users
# Creates user pipeline directories under /work/$USER/pipelines/
# and copies template configs with placeholder substitution.
#
# Usage: /groups/tprice/pipelines/bin/tjp-setup

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

# ── Pre-flight checks ───────────────────────────────────────────────────────
hyperion_banner "SETUP"

info "Checking HPC environment..."

# Check apptainer is available
if ! command -v apptainer &>/dev/null; then
    if command -v module &>/dev/null; then
        module load apptainer 2>/dev/null || true
    fi
fi
if ! command -v apptainer &>/dev/null; then
    warn "Apptainer not found. You may need to run 'module load apptainer' before launching pipelines."
fi

# Check containers exist (skip native pipelines)
local_errors=()
for pipeline in "${KNOWN_PIPELINES[@]}"; do
    if is_native_pipeline "$pipeline"; then
        continue
    fi
    container_path=$(get_container_path "$pipeline")
    if is_multicontainer_pipeline "$pipeline"; then
        if [[ ! -d "$container_path" ]]; then
            warn "Container directory not found: $container_path"
            warn "  → Run: git submodule update --init containers/virome"
        elif ! ls "$container_path"/*.sif &>/dev/null 2>&1; then
            warn "No containers built yet in: $container_path"
            warn "  → Copy built .sif files there, or run: sbatch $REPO_ROOT/containers/virome/scripts/build_containers.sh"
        fi
    elif [[ ! -f "$container_path" ]]; then
        warn "Container not found: $container_path"
        warn "  → It may not have been transferred to HPC yet."
    fi
done

# Check 10x tool installations
for tool in cellranger spaceranger xeniumranger; do
    tool_dir=$(get_tool_path "$tool")
    if [[ ! -d "$tool_dir" ]]; then
        warn "10x tool not found: $tool_dir"
        warn "  → Extract tarball to /groups/tprice/opt/"
    fi
done

# Check UTDal pipeline repo for bulkrnaseq
PIPELINE_REPO="$REPO_ROOT/Bulk-RNA-Seq-Nextflow-Pipeline"
if [[ ! -d "$PIPELINE_REPO" ]]; then
    warn "UTDal Bulk-RNA-Seq pipeline repo not found at $PIPELINE_REPO"
    warn "  → Clone it: cd $REPO_ROOT && git clone https://github.com/utdal/Bulk-RNA-Seq-Nextflow-Pipeline.git"
fi

# Check work directory exists
if [[ ! -d "$WORK_ROOT" ]]; then
    die "Work directory $WORK_ROOT does not exist. Contact your HPC administrator."
fi

# ── Create workspace ────────────────────────────────────────────────────────
header "Creating workspace"

for pipeline in "${KNOWN_PIPELINES[@]}"; do
    pipeline_dir="$USER_PIPELINES/$pipeline"

    if [[ -d "$pipeline_dir" ]]; then
        info "Directory already exists: $pipeline_dir"
    else
        mkdir -p "$pipeline_dir"
        info "Created: $pipeline_dir"
    fi

    # Create runs directory
    mkdir -p "$pipeline_dir/runs"
done

# ── Copy template configs ───────────────────────────────────────────────────
header "Setting up config files"

_substitute_placeholders() {
    sed \
        -e "s|__USER__|$USER|g" \
        -e "s|__SCRATCH__|$SCRATCH_ROOT|g" \
        -e "s|__WORK__|$WORK_ROOT|g" \
        -e "s|__REPO_ROOT__|$REPO_ROOT|g" \
        "$1"
}

# AddOne config
addone_config="$USER_PIPELINES/addone/config.yaml"
if [[ -f "$addone_config" ]]; then
    warn "Config already exists, skipping: $addone_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/addone/config.yaml" > "$addone_config"
    info "Created: $addone_config"
fi

# BulkRNASeq config
bulkrnaseq_config="$USER_PIPELINES/bulkrnaseq/config.yaml"
if [[ -f "$bulkrnaseq_config" ]]; then
    warn "Config already exists, skipping: $bulkrnaseq_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/bulkrnaseq/config.yaml" > "$bulkrnaseq_config"
    info "Created: $bulkrnaseq_config"
fi

# BulkRNASeq samples example
bulkrnaseq_samples="$USER_PIPELINES/bulkrnaseq/samples.txt"
if [[ -f "$bulkrnaseq_samples" ]]; then
    warn "Samples file already exists, skipping: $bulkrnaseq_samples"
else
    cp "$REPO_ROOT/templates/bulkrnaseq/samples_example.txt" "$bulkrnaseq_samples"
    info "Created: $bulkrnaseq_samples"
fi

# Psoma config
psoma_config="$USER_PIPELINES/psoma/config.yaml"
if [[ -f "$psoma_config" ]]; then
    warn "Config already exists, skipping: $psoma_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/psoma/config.yaml" > "$psoma_config"
    info "Created: $psoma_config"
fi

# Psoma samples example
psoma_samples="$USER_PIPELINES/psoma/samples.txt"
if [[ -f "$psoma_samples" ]]; then
    warn "Samples file already exists, skipping: $psoma_samples"
else
    cp "$REPO_ROOT/templates/psoma/samples_example.txt" "$psoma_samples"
    info "Created: $psoma_samples"
fi

# Virome config
virome_config="$USER_PIPELINES/virome/config.yaml"
if [[ -f "$virome_config" ]]; then
    warn "Config already exists, skipping: $virome_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/virome/config.yaml" > "$virome_config"
    info "Created: $virome_config"
fi

# Virome samplesheet example
virome_samplesheet="$USER_PIPELINES/virome/samplesheet.csv"
if [[ -f "$virome_samplesheet" ]]; then
    warn "Samplesheet already exists, skipping: $virome_samplesheet"
else
    cp "$REPO_ROOT/templates/virome/samplesheet_example.csv" "$virome_samplesheet"
    info "Created: $virome_samplesheet"
fi

# Cell Ranger config
cellranger_config="$USER_PIPELINES/cellranger/config.yaml"
if [[ -f "$cellranger_config" ]]; then
    warn "Config already exists, skipping: $cellranger_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/cellranger/config.yaml" > "$cellranger_config"
    info "Created: $cellranger_config"
fi

# Space Ranger config
spaceranger_config="$USER_PIPELINES/spaceranger/config.yaml"
if [[ -f "$spaceranger_config" ]]; then
    warn "Config already exists, skipping: $spaceranger_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/spaceranger/config.yaml" > "$spaceranger_config"
    info "Created: $spaceranger_config"
fi

# Xenium Ranger config
xeniumranger_config="$USER_PIPELINES/xeniumranger/config.yaml"
if [[ -f "$xeniumranger_config" ]]; then
    warn "Config already exists, skipping: $xeniumranger_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/xeniumranger/config.yaml" > "$xeniumranger_config"
    info "Created: $xeniumranger_config"
fi

# SQANTI3 config
sqanti3_config="$USER_PIPELINES/sqanti3/config.yaml"
if [[ -f "$sqanti3_config" ]]; then
    warn "Config already exists, skipping: $sqanti3_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/sqanti3/config.yaml" > "$sqanti3_config"
    info "Created: $sqanti3_config"
fi

# wf-transcriptomes config
wf_transcriptomes_config="$USER_PIPELINES/wf-transcriptomes/config.yaml"
if [[ -f "$wf_transcriptomes_config" ]]; then
    warn "Config already exists, skipping: $wf_transcriptomes_config"
else
    _substitute_placeholders "$REPO_ROOT/templates/wf-transcriptomes/config.yaml" > "$wf_transcriptomes_config"
    info "Created: $wf_transcriptomes_config"
fi

# ── Add to PATH ────────────────────────────────────────────────────────────
PATH_LINE="export PATH=\"$REPO_ROOT/bin:\$PATH\""
BASHRC="$HOME/.bashrc"

if grep -qF "$REPO_ROOT/bin" "$BASHRC" 2>/dev/null; then
    info "PATH already configured in $BASHRC"
else
    echo "" >> "$BASHRC"
    echo "# Hyperion Compute — TJP pipeline tools" >> "$BASHRC"
    echo "$PATH_LINE" >> "$BASHRC"
    info "Added pipeline tools to PATH in $BASHRC"
    export PATH="$REPO_ROOT/bin:$PATH"
fi

# ── Print next steps ────────────────────────────────────────────────────────
hyperion_sign_off

cat <<EOF
Your workspace is ready at: $USER_PIPELINES/

Next steps:

  1. Edit a pipeline config:

     vi $USER_PIPELINES/addone/config.yaml        # simple demo
     vi $USER_PIPELINES/bulkrnaseq/config.yaml     # RNA-seq (STAR aligner)
     vi $USER_PIPELINES/psoma/config.yaml          # RNA-seq (HISAT2/Trimmomatic)
     vi $USER_PIPELINES/virome/config.yaml         # viral profiling from bulk RNA-seq
     vi $USER_PIPELINES/cellranger/config.yaml     # 10x single-cell
     vi $USER_PIPELINES/spaceranger/config.yaml    # 10x spatial
     vi $USER_PIPELINES/xeniumranger/config.yaml   # 10x in situ

  2. Launch a pipeline:

     tjp-launch addone
     tjp-launch bulkrnaseq
     tjp-launch psoma
     tjp-launch virome
     tjp-launch cellranger
     tjp-launch spaceranger
     tjp-launch xeniumranger

See USER_GUIDE.md for detailed documentation.
EOF
