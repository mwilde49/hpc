#!/usr/bin/env bash
# tjp-test — smoke-test a TJP RNA-Seq pipeline with subsampled data
# Copies test FASTQs to scratch, generates a test config, and delegates
# to tjp-launch --dev for submission to the dev partition.
#
# Usage: tjp-test <pipeline> [--clean]
#
# Supported pipelines: psoma, bulkrnaseq
#
# Examples:
#   tjp-test psoma              # run psoma smoke test
#   tjp-test bulkrnaseq         # run bulkrnaseq smoke test
#   tjp-test psoma --clean      # wipe previous test data first

set -euo pipefail

# Source shared libraries
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

# ── Constants ────────────────────────────────────────────────────────────────
TEST_DATA_SRC="$REPO_ROOT/test_data/rnaseq"
TEST_DATA_10X="$REPO_ROOT/test_data/10x"
SUPPORTED_PIPELINES=(psoma bulkrnaseq virome cellranger spaceranger sqanti3 wf-transcriptomes)

# ── Usage ────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage: tjp-test <pipeline> [--clean]

Smoke-test a pipeline with 2 subsampled samples on the dev partition.

Pipelines: ${SUPPORTED_PIPELINES[*]}

Options:
  --clean   Wipe previous test data in scratch before copying
  --help    Show this help message

Workflow:
  1. tjp-test psoma              # submit smoke test
  2. squeue -u \$USER             # monitor job
  3. tjp-test-validate psoma     # validate outputs after completion
EOF
    exit "${1:-0}"
}

# ── Argument parsing ─────────────────────────────────────────────────────────
PIPELINE=""
CLEAN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --clean)  CLEAN=true; shift ;;
        --help|-h) usage 0 ;;
        -*)       die "Unknown option: $1" ;;
        *)
            if [[ -z "$PIPELINE" ]]; then
                PIPELINE="$1"
            else
                die "Unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -z "$PIPELINE" ]] && usage 1

# ── Validate pipeline ────────────────────────────────────────────────────────
is_supported=false
for p in "${SUPPORTED_PIPELINES[@]}"; do
    [[ "$p" == "$PIPELINE" ]] && is_supported=true
done
$is_supported || die "Unsupported pipeline: $PIPELINE (supported: ${SUPPORTED_PIPELINES[*]})"

# ── Paths ────────────────────────────────────────────────────────────────────
SCRATCH_TEST_DIR="$SCRATCH_ROOT/pipelines/$PIPELINE/test_data"
SCRATCH_FASTQ_DIR="$SCRATCH_TEST_DIR/fastq"

if [[ "$PIPELINE" == "sqanti3" ]]; then
    # SQANTI3 uses GTF/FASTA inputs, not FASTQs
    SQANTI3_TEST_DATA="$REPO_ROOT/containers/sqanti3/SQANTI3/data"
    SRC_FASTQ_DIR=""
    SRC_SAMPLES=""
elif [[ "$PIPELINE" == "wf-transcriptomes" ]]; then
    # wf-transcriptomes uses ONT FASTQs — must be staged manually (see containers/sqanti3/test_data/wf_transcriptomes)
    WF_TX_TEST_DATA="$REPO_ROOT/containers/sqanti3/test_data/wf_transcriptomes"
    SRC_FASTQ_DIR=""
    SRC_SAMPLES=""
elif [[ "$PIPELINE" == "virome" ]]; then
    SRC_FASTQ_DIR="$TEST_DATA_SRC/fastq"
    SRC_SAMPLES=""
elif [[ "$PIPELINE" == "cellranger" ]]; then
    SRC_FASTQ_DIR="$TEST_DATA_10X/cellranger/fastq"
    SRC_SAMPLES=""
elif [[ "$PIPELINE" == "spaceranger" ]]; then
    # Space Ranger ships with tiny test inputs in the install directory
    SPACERANGER_DIR=$(get_tool_path spaceranger)
    SRC_FASTQ_DIR="$SPACERANGER_DIR/external/spaceranger_tiny_inputs/fastqs"
    SRC_IMAGE="$SPACERANGER_DIR/external/spaceranger_tiny_inputs/image/tinyimage.jpg"
    SRC_REF="$SPACERANGER_DIR/external/spaceranger_tiny_ref"
    SRC_SAMPLES=""
else
    SRC_FASTQ_DIR="$TEST_DATA_SRC/fastq"
    SRC_SAMPLES="$TEST_DATA_SRC/$PIPELINE/samples.txt"
fi

hyperion_banner "SMOKE TEST"

# ── SQANTI3: separate code path (no FASTQs) ──────────────────────────────────
if [[ "$PIPELINE" == "sqanti3" ]]; then
    if [[ ! -d "$SQANTI3_TEST_DATA" ]]; then
        die "SQANTI3 test data not found: $SQANTI3_TEST_DATA
  Ensure the sqanti3 submodule is checked out: git submodule update --init containers/sqanti3"
    fi

    SQANTI3_OUTDIR="$SCRATCH_ROOT/pipelines/sqanti3/test_data/results"
    TEST_CONFIG="$SCRATCH_ROOT/pipelines/sqanti3/test_data/config.yaml"
    mkdir -p "$(dirname "$TEST_CONFIG")"

    cat > "$TEST_CONFIG" <<YAML
sample: UHR_chr22_test
isoforms: ${SQANTI3_TEST_DATA}/UHR_chr22.gtf
refGTF:   ${SQANTI3_TEST_DATA}/reference/gencode.v38.basic_chr22.gtf
refFasta: ${SQANTI3_TEST_DATA}/reference/GRCh38.p13_chr22.fasta
coverage: ""
fl_count: ${SQANTI3_TEST_DATA}/UHR_abundance.tsv
CAGE_peak:        ${SQANTI3_TEST_DATA}/ref_TSS_annotation/human.refTSS_v3.1.hg38.bed
polyA_motif_list: ${SQANTI3_TEST_DATA}/polyA_motifs/mouse_and_human.polyA_motif.txt
polyA_peak: ""
force_id_ignore: false
cpus:   4
chunks: 1
skip_report: true
skip_orf: false
filter_mode: rules
filter_mono_exonic: false
rescue_mode: automatic
outdir: ${SQANTI3_OUTDIR}
YAML

    info "Generated SQANTI3 test config: $TEST_CONFIG"
    info "Delegating to tjp-launch sqanti3 --dev --config $TEST_CONFIG"
    echo ""
    "$SCRIPT_DIR/tjp-launch" sqanti3 --dev --config "$TEST_CONFIG"

    echo ""
    info "After job completes, validate outputs with:"
    echo "  tjp-test-validate sqanti3"
    exit 0
fi

# ── wf-transcriptomes: separate code path (needs staged ONT FASTQs) ───────────
if [[ "$PIPELINE" == "wf-transcriptomes" ]]; then
    WFTX_FASTQ_DIR="$WF_TX_TEST_DATA/fastq"
    WFTX_SAMPLE_SHEET="$WF_TX_TEST_DATA/sample_sheet.csv"
    WFTX_OUTDIR="$SCRATCH_ROOT/pipelines/wf-transcriptomes/test_data/results"
    TEST_CONFIG="$SCRATCH_ROOT/pipelines/wf-transcriptomes/test_data/config.yaml"

    if [[ ! -d "$WFTX_FASTQ_DIR" ]]; then
        die "wf-transcriptomes test FASTQ dir not found: $WFTX_FASTQ_DIR
  Stage test ONT FASTQs first — see $WF_TX_TEST_DATA/README.md"
    fi

    if [[ ! -f "$WFTX_SAMPLE_SHEET" ]]; then
        die "wf-transcriptomes test sample sheet not found: $WFTX_SAMPLE_SHEET
  Create a CSV with columns: barcode,alias"
    fi

    mkdir -p "$(dirname "$TEST_CONFIG")"

    cat > "$TEST_CONFIG" <<YAML
sample:         wftx_test
fastq_dir:      ${WFTX_FASTQ_DIR}
sample_sheet:   ${WFTX_SAMPLE_SHEET}
ref_genome:     /groups/tprice/pipelines/references/GRCh38.primary_assembly.genome.fa
ref_annotation: /groups/tprice/pipelines/references/gencode.v47.primary_assembly.annotation.gtf
wf_version:     v2.3.0
direct_rna:     false
minimap2_index_opts: "-k 15"
min_read_length: 100
min_qscore:     9
de_analysis:    false
outdir:         ${WFTX_OUTDIR}
YAML

    info "Generated wf-transcriptomes test config: $TEST_CONFIG"
    info "Delegating to tjp-launch wf-transcriptomes --dev --config $TEST_CONFIG"
    echo ""
    "$SCRIPT_DIR/tjp-launch" wf-transcriptomes --dev --config "$TEST_CONFIG"

    echo ""
    info "Monitor: squeue -u $USER"
    info "Output will be at: $WFTX_OUTDIR"
    exit 0
fi

# ── Pre-flight checks ────────────────────────────────────────────────────────
if [[ ! -d "$SRC_FASTQ_DIR" ]]; then
    die "Test FASTQ directory not found: $SRC_FASTQ_DIR
  Stage test data first (see test_data/ README)."
fi

if [[ -n "$SRC_SAMPLES" && ! -f "$SRC_SAMPLES" ]]; then
    die "Samples file not found: $SRC_SAMPLES"
fi

# Check test FASTQs exist (at least one file)
shopt -s nullglob
src_files=("$SRC_FASTQ_DIR"/*.fastq.gz)
shopt -u nullglob
if [[ ${#src_files[@]} -eq 0 ]]; then
    die "No .fastq.gz files found in $SRC_FASTQ_DIR
  Stage test data first (see test_data/ README)."
fi

# ── Clean if requested ────────────────────────────────────────────────────────
if $CLEAN && [[ -d "$SCRATCH_TEST_DIR" ]]; then
    info "Cleaning previous test data: $SCRATCH_TEST_DIR"
    rm -rf "$SCRATCH_TEST_DIR"
fi

# ── Copy test FASTQs to scratch ──────────────────────────────────────────────
mkdir -p "$SCRATCH_FASTQ_DIR"

if [[ "$PIPELINE" == "virome" ]]; then
    # Virome uses _1/_2 suffixes — copy files as-is (samplesheet built below)
    for f in "$SRC_FASTQ_DIR"/*_1.fastq.gz "$SRC_FASTQ_DIR"/*_2.fastq.gz; do
        [[ -f "$f" ]] || continue
        dest="$SCRATCH_FASTQ_DIR/$(basename "$f")"
        if [[ ! -f "$dest" ]]; then
            info "Copying $(basename "$f") to scratch..."
            cp "$f" "$dest"
        fi
    done
elif [[ "$PIPELINE" == "psoma" ]]; then
    # Psoma uses _1/_2 suffixes — copy files as-is
    for f in "$SRC_FASTQ_DIR"/*_1.fastq.gz "$SRC_FASTQ_DIR"/*_2.fastq.gz; do
        [[ -f "$f" ]] || continue
        dest="$SCRATCH_FASTQ_DIR/$(basename "$f")"
        if [[ ! -f "$dest" ]]; then
            info "Copying $(basename "$f") to scratch..."
            cp "$f" "$dest"
        fi
    done
elif [[ "$PIPELINE" == "bulkrnaseq" ]]; then
    # BulkRNASeq uses _R1_001/_R2_001 suffixes — create renamed copies/symlinks
    for f in "$SRC_FASTQ_DIR"/*_1.fastq.gz; do
        [[ -f "$f" ]] || continue
        base=$(basename "$f")
        # Sample_19_1.fastq.gz -> Sample_19_R1_001.fastq.gz
        newname="${base/_1.fastq.gz/_R1_001.fastq.gz}"
        dest="$SCRATCH_FASTQ_DIR/$newname"
        if [[ ! -f "$dest" ]]; then
            info "Copying $base -> $newname"
            cp "$f" "$dest"
        fi
    done
    for f in "$SRC_FASTQ_DIR"/*_2.fastq.gz; do
        [[ -f "$f" ]] || continue
        base=$(basename "$f")
        # Sample_19_2.fastq.gz -> Sample_19_R2_001.fastq.gz
        newname="${base/_2.fastq.gz/_R2_001.fastq.gz}"
        dest="$SCRATCH_FASTQ_DIR/$newname"
        if [[ ! -f "$dest" ]]; then
            info "Copying $base -> $newname"
            cp "$f" "$dest"
        fi
    done
elif [[ "$PIPELINE" == "cellranger" || "$PIPELINE" == "spaceranger" ]]; then
    # 10x pipelines use standard Illumina naming — copy as-is
    for f in "$SRC_FASTQ_DIR"/*.fastq.gz; do
        [[ -f "$f" ]] || continue
        dest="$SCRATCH_FASTQ_DIR/$(basename "$f")"
        if [[ ! -f "$dest" ]]; then
            info "Copying $(basename "$f") to scratch..."
            cp "$f" "$dest"
        fi
    done
    # Space Ranger also needs the image file
    if [[ "$PIPELINE" == "spaceranger" ]]; then
        mkdir -p "$SCRATCH_TEST_DIR/image"
        cp "$SRC_IMAGE" "$SCRATCH_TEST_DIR/image/"
        info "Copied test image: $(basename "$SRC_IMAGE")"
    fi
fi

# ── Copy samples file (RNA-seq pipelines only) ──────────────────────────────
if [[ -n "$SRC_SAMPLES" ]]; then
    cp "$SRC_SAMPLES" "$SCRATCH_TEST_DIR/samples.txt"
    info "Samples file: $SCRATCH_TEST_DIR/samples.txt"
fi

# ── Generate test config YAML ────────────────────────────────────────────────
TEST_CONFIG="$SCRATCH_TEST_DIR/config.yaml"

if [[ "$PIPELINE" == "virome" ]]; then
    # Build samplesheet CSV from copied FASTQs
    SAMPLESHEET="$SCRATCH_TEST_DIR/samplesheet.csv"
    echo "sample,fastq_r1,fastq_r2" > "$SAMPLESHEET"
    for r1 in "$SCRATCH_FASTQ_DIR"/*_1.fastq.gz; do
        [[ -f "$r1" ]] || continue
        r2="${r1/_1.fastq.gz/_2.fastq.gz}"
        if [[ -f "$r2" ]]; then
            sample=$(basename "$r1" _1.fastq.gz)
            echo "$sample,$r1,$r2" >> "$SAMPLESHEET"
        fi
    done
    info "Generated samplesheet: $SAMPLESHEET"

    VIROME_OUTDIR="$SCRATCH_ROOT/pipelines/virome/test_data/results"
    cat > "$TEST_CONFIG" <<YAML
project_name: Virome-Test-2samples
samplesheet: $SAMPLESHEET
outdir: $VIROME_OUTDIR
star_index: /groups/tprice/pipelines/references/star_index
kraken2_db: /groups/tprice/pipelines/references/kraken2_viral_db
adapters: $REPO_ROOT/containers/virome/assets/NexteraPE-PE.fa
container_dir: $REPO_ROOT/containers/virome
trim_headcrop: 0
trim_leading: 3
trim_trailing: 3
trim_slidingwindow: "4:15"
trim_minlen: 36
kraken2_confidence: 0.1
min_reads_per_taxon: 5
YAML
elif [[ "$PIPELINE" == "psoma" ]]; then
    cat > "$TEST_CONFIG" <<YAML
project_name: Psoma-Test-2samples
species: Human
paired_end: true
fastq_dir: $SCRATCH_FASTQ_DIR
samples_file: $SCRATCH_TEST_DIR/samples.txt
hisat2_index: /groups/tprice/pipelines/references/hisat2_index/gencode48
reference_gtf: /groups/tprice/pipelines/references/gencode.v48.primary_assembly.annotation.gtf
exclude_bed_file_path: /groups/tprice/pipelines/references/filter.bed
blacklist_bed_file_path: /groups/tprice/pipelines/references/blacklist.bed
read1_suffix: _1
read2_suffix: _2
headcrop: 10
leading: 3
trailing: 3
slidingwindow: "4:15"
minlen: 36
illuminaclip_params: "2:30:10:5:true"
strand_st: --rf
strand_hts: reverse
paired_hts: pos
fastqc_cores: 40
run_fastqc: true
run_rna_pipeline: true
YAML
elif [[ "$PIPELINE" == "bulkrnaseq" ]]; then
    cat > "$TEST_CONFIG" <<YAML
project_name: BulkRNASeq-Test-2samples
species: Human
paired_end: true
fastq_dir: $SCRATCH_FASTQ_DIR
samples_file: $SCRATCH_TEST_DIR/samples.txt
star_index: /groups/tprice/pipelines/references/star_index
reference_gtf: /groups/tprice/pipelines/references/gencode.v48.primary_assembly.annotation.gtf
exclude_bed_file_path: /groups/tprice/pipelines/references/filter.bed
blacklist_bed_file_path: /groups/tprice/pipelines/references/blacklist.bed
read1_suffix: _R1_001
read2_suffix: _R2_001
clip5_num: 11
clip3_num: 5
strand_st: --rf
strand_hts: reverse
paired_hts: pos
fastqc_cores: 40
run_fastqc: true
run_rna_pipeline: true
YAML
elif [[ "$PIPELINE" == "cellranger" ]]; then
    # Derive sample_name from the first FASTQ filename
    shopt -s nullglob
    test_fastqs=("$SCRATCH_FASTQ_DIR"/*_R1_001.fastq.gz "$SCRATCH_FASTQ_DIR"/*_R1.fastq.gz)
    shopt -u nullglob
    test_sample_name="test_sample"
    if [[ ${#test_fastqs[@]} -gt 0 ]]; then
        test_sample_name=$(basename "${test_fastqs[0]}" | sed 's/_S[0-9]*_L[0-9]*_R[12]_001\.fastq\.gz$//' | sed 's/_R[12]\.fastq\.gz$//')
    fi
    cat > "$TEST_CONFIG" <<YAML
sample_id: cellranger_test
sample_name: $test_sample_name
fastq_dir: $SCRATCH_FASTQ_DIR
transcriptome: /groups/tprice/pipelines/references/refdata-gex-GRCh38-2024-A
localcores: 16
localmem: 120
create_bam: true
YAML
elif [[ "$PIPELINE" == "spaceranger" ]]; then
    cat > "$TEST_CONFIG" <<YAML
sample_id: spaceranger_test
sample_name: tinytest
fastq_dir: $SCRATCH_FASTQ_DIR
transcriptome: $SRC_REF
image: $SCRATCH_TEST_DIR/image/tinyimage.jpg
unknown_slide: visium-1
localcores: 16
localmem: 120
create_bam: true
YAML
fi

info "Generated test config: $TEST_CONFIG"

# ── Delegate to tjp-launch ───────────────────────────────────────────────────
info "Delegating to tjp-launch $PIPELINE --dev --config $TEST_CONFIG"
echo ""
"$SCRIPT_DIR/tjp-launch" "$PIPELINE" --dev --config "$TEST_CONFIG"

# ── Post-launch instructions ─────────────────────────────────────────────────
echo ""
info "After job completes, validate outputs with:"
echo "  tjp-test-validate $PIPELINE"
