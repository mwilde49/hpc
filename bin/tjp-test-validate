#!/usr/bin/env bash
# tjp-test-validate — validate outputs from a tjp-test smoke test run
# Checks that expected output directories and key files exist.
#
# Usage: tjp-test-validate <pipeline> [--run <timestamp>]
#
# If --run is not given, uses the most recent run directory.

set -euo pipefail

# Source shared libraries
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

SUPPORTED_PIPELINES=(psoma bulkrnaseq virome cellranger spaceranger)

# ── Usage ────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage: tjp-test-validate <pipeline> [--run <timestamp>]

Validate outputs from a smoke test run.

Pipelines: ${SUPPORTED_PIPELINES[*]}

Options:
  --run <timestamp>   Validate a specific run (default: most recent)
  --help              Show this help message
EOF
    exit "${1:-0}"
}

# ── Argument parsing ─────────────────────────────────────────────────────────
PIPELINE=""
RUN_TS=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --run)
            [[ $# -lt 2 ]] && die "--run requires a timestamp argument"
            RUN_TS="$2"; shift 2 ;;
        --help|-h) usage 0 ;;
        -*)       die "Unknown option: $1" ;;
        *)
            if [[ -z "$PIPELINE" ]]; then
                PIPELINE="$1"
            else
                die "Unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -z "$PIPELINE" ]] && usage 1

is_supported=false
for p in "${SUPPORTED_PIPELINES[@]}"; do
    [[ "$p" == "$PIPELINE" ]] && is_supported=true
done
$is_supported || die "Unsupported pipeline: $PIPELINE (supported: ${SUPPORTED_PIPELINES[*]})"

# ── Find the run directory ───────────────────────────────────────────────────
# Virome outputs are staged to work after completion; validate against work archive.
# All other pipelines are validated against their scratch run directories.
if [[ "$PIPELINE" == "virome" ]]; then
    RUNS_BASE="$WORK_ROOT/pipelines/$PIPELINE/runs"
else
    RUNS_BASE="$SCRATCH_ROOT/pipelines/$PIPELINE/runs"
fi

if [[ -n "$RUN_TS" ]]; then
    if [[ "$PIPELINE" == "virome" ]]; then
        RUN_DIR="$RUNS_BASE/$RUN_TS/outputs"
    else
        RUN_DIR="$RUNS_BASE/$RUN_TS"
    fi
    if [[ ! -d "$RUN_DIR" ]]; then
        die "Run directory not found: $RUN_DIR"
    fi
else
    if [[ ! -d "$RUNS_BASE" ]]; then
        die "No runs directory found: $RUNS_BASE"
    fi
    latest=$(find "$RUNS_BASE" -mindepth 1 -maxdepth 1 -type d | sort | tail -1)
    if [[ -z "$latest" ]]; then
        die "No runs found in $RUNS_BASE"
    fi
    RUN_TS=$(basename "$latest")
    if [[ "$PIPELINE" == "virome" ]]; then
        RUN_DIR="$latest/outputs"
    else
        RUN_DIR="$latest"
    fi
fi

hyperion_banner "VALIDATION"
info "Run: $RUN_TS"
info "Output dir: $RUN_DIR"
echo ""

# ── Define expected outputs ──────────────────────────────────────────────────
declare -a CHECK_DIRS
declare -a CHECK_FILES

if [[ "$PIPELINE" == "virome" ]]; then
    CHECK_DIRS=(
        "results"
        "multiqc"
        "multiqc/multiqc_data"
    )
    CHECK_FILES=(
        "results/viral_abundance_matrix.tsv"
        "results/viral_abundance_matrix.csv"
        "multiqc/multiqc_report.html"
    )
elif [[ "$PIPELINE" == "psoma" ]]; then
    CHECK_DIRS=(
        "2_trim_output"
        "3_hisat2_mapping_output"
        "4_filter_output"
        "5_stringtie_counts_output"
        "6_raw_counts_output"
    )
    CHECK_FILES=(
        "3_hisat2_mapping_output/*.sorted.bam"
        "4_filter_output/*.filt.bam"
        "5_stringtie_counts_output/genes.tpm.txt"
        "6_raw_counts_output/raw_htseq_counts.csv"
    )
elif [[ "$PIPELINE" == "bulkrnaseq" ]]; then
    CHECK_DIRS=(
        "2_star_mapping_output"
        "3_filter_output"
        "4_stringtie_counts_output"
        "5_raw_counts_output"
    )
    CHECK_FILES=(
        "2_star_mapping_output/*Aligned.sortedByCoord.out.bam"
        "3_filter_output/*.filt.bam"
        "4_stringtie_counts_output/genes.tpm.txt"
        "5_raw_counts_output/raw_htseq_counts.csv"
    )
elif [[ "$PIPELINE" == "cellranger" ]]; then
    # Cell Ranger outputs are under <sample_id>/outs/
    # Try to find the sample_id from the work run config
    WORK_RUNS="$WORK_ROOT/pipelines/$PIPELINE/runs"
    sample_id="cellranger_test"
    if [[ -n "$RUN_TS" && -f "$WORK_RUNS/$RUN_TS/config.yaml" ]]; then
        sample_id=$(yaml_get "$WORK_RUNS/$RUN_TS/config.yaml" "sample_id" 2>/dev/null || echo "cellranger_test")
    fi
    CHECK_DIRS=(
        "$sample_id/outs"
        "$sample_id/outs/filtered_feature_bc_matrix"
        "$sample_id/outs/raw_feature_bc_matrix"
    )
    CHECK_FILES=(
        "$sample_id/outs/web_summary.html"
        "$sample_id/outs/metrics_summary.csv"
        "$sample_id/outs/filtered_feature_bc_matrix/barcodes.tsv.gz"
        "$sample_id/outs/filtered_feature_bc_matrix/features.tsv.gz"
        "$sample_id/outs/filtered_feature_bc_matrix/matrix.mtx.gz"
    )
elif [[ "$PIPELINE" == "spaceranger" ]]; then
    # Space Ranger outputs are under <sample_id>/outs/
    WORK_RUNS="$WORK_ROOT/pipelines/$PIPELINE/runs"
    sample_id="spaceranger_test"
    if [[ -n "$RUN_TS" && -f "$WORK_RUNS/$RUN_TS/config.yaml" ]]; then
        sample_id=$(yaml_get "$WORK_RUNS/$RUN_TS/config.yaml" "sample_id" 2>/dev/null || echo "spaceranger_test")
    fi
    CHECK_DIRS=(
        "$sample_id/outs"
        "$sample_id/outs/spatial"
        "$sample_id/outs/filtered_feature_bc_matrix"
        "$sample_id/outs/raw_feature_bc_matrix"
    )
    CHECK_FILES=(
        "$sample_id/outs/web_summary.html"
        "$sample_id/outs/metrics_summary.csv"
        "$sample_id/outs/spatial/tissue_positions.csv"
        "$sample_id/outs/spatial/scalefactors_json.json"
        "$sample_id/outs/filtered_feature_bc_matrix.h5"
    )
fi

# ── Check directories ────────────────────────────────────────────────────────
PASS=0
FAIL=0

for dir in "${CHECK_DIRS[@]}"; do
    full_path="$RUN_DIR/$dir"
    if [[ -d "$full_path" ]]; then
        # Count files in directory
        file_count=$(find "$full_path" -type f | wc -l)
        printf "  ${_GREEN}PASS${_RESET}  %-40s (%d files)\n" "$dir/" "$file_count"
        PASS=$((PASS + 1))
    else
        printf "  ${_RED}FAIL${_RESET}  %-40s (directory missing)\n" "$dir/"
        FAIL=$((FAIL + 1))
    fi
done

echo ""

# ── Check key files ──────────────────────────────────────────────────────────
for pattern in "${CHECK_FILES[@]}"; do
    shopt -s nullglob
    matches=("$RUN_DIR"/$pattern)
    shopt -u nullglob

    if [[ ${#matches[@]} -gt 0 ]]; then
        for f in "${matches[@]}"; do
            size=$(du -h "$f" | cut -f1)
            rel_path="${f#$RUN_DIR/}"
            printf "  ${_GREEN}PASS${_RESET}  %-40s (%s)\n" "$rel_path" "$size"
        done
        PASS=$((PASS + 1))
    else
        printf "  ${_RED}FAIL${_RESET}  %-40s (no matches)\n" "$pattern"
        FAIL=$((FAIL + 1))
    fi
done

# ── Summary ──────────────────────────────────────────────────────────────────
echo ""
TOTAL=$((PASS + FAIL))
if [[ $FAIL -eq 0 ]]; then
    hyperion_milestone "Mission Complete — All $TOTAL checks passed"
    hyperion_sign_off
    exit 0
else
    hyperion_milestone "Mission Incomplete — $FAIL/$TOTAL checks failed"
    exit 1
fi
